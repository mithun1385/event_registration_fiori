<mvc:View
    controllerName="project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <tnt:ToolHeader
            id="shellLikeToolHeader"
            class="sapUiTinyMargin"
        >
            <Button
                id="_IDGenButton1"
                icon="sap-icon://menu2"
                type="Transparent"
                tooltip="Menu"
                press=".onCollapseExpandPress"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Button>
            <Image
                id="_IDGenImage"
                src="test-resources/sap/tnt/images/SAP_Logo.png"
                decorative="false"
                press="onLogoPressed"
                tooltip="SAP Logo"
                width="60px"
                height="30px"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData1"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Image>
            <Title
                text="Prоduct Name"
                wrapping="false"
                id="productName"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData2"
                        priority="Disappear"
                    />
                </layoutData>
            </Title>
            <Text
                text="Second title"
                wrapping="false"
                id="secondTitle"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData3"
                        priority="Disappear"
                    />
                </layoutData>
            </Text>
            <ToolbarSpacer id="_IDGenToolbarSpacer" />
            <SearchField
                width="25rem"
                id="searchField"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData4"
                        priority="Low"
                        group="1"
                    />
                </layoutData>
            </SearchField>
            <Button
                visible="false"
                icon="sap-icon://search"
                type="Transparent"
                id="searchButton"
                tooltip="Search"
            />
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton"
                icon="sap-icon://da"
                type="Transparent"
                tooltip="Joule"
                text="Joule"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData5"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton1"
                icon="sap-icon://source-code"
                type="Transparent"
                tooltip="Action 1"
                text="Action 1"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData6"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton2"
                icon="sap-icon://card"
                type="Transparent"
                tooltip="Action 2"
                text="Action 2"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData7"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton3"
                icon="sap-icon://action-settings"
                type="Transparent"
                text="Settings"
            />
            <Button
                id="_IDGenButton2"
                icon="sap-icon://bell"
                type="Transparent"
                tooltip="Notification"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData8"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Button>
            <tnt:ToolHeaderUtilitySeparator
                id="_IDGenToolHeaderUtilitySeparator"
            />
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton4"
                icon="sap-icon://grid"
                type="Transparent"
                text="My Products"
                tooltip="My Products"
            />
            <Avatar
                id="_IDGenAvatar"
                src="test-resources/sap/tnt/"
                displaySize="XS"
                press=".onAvatarPressed"
                tooltip="Profile"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData9"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Avatar>
        </tnt:ToolHeader>

        <!-- side navigation -->

        <HBox id="_IDGenHBox">
            <VBox id="_IDGenVBox">
                <tnt:SideNavigation
                    id="sideNavigation"
                    selectedKey="walked"
                    expanded="true"
                >
                    <tnt:NavigationList id="_IDGenNavigationList">
                        <tnt:NavigationListItem
                            id="_IDGenNavigationListItem1"
                            text="Home"
                            icon="sap-icon://home"
                        />
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup"
                            text="New"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem2"
                                text="RegisterDetails"
                                icon="sap-icon://people-connected"
                                press="RegisterDetails"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem3"
                                text="viewDetails"
                                icon="sap-icon://building"
                                press="viewDetails"
                            >
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem4"
                                    text="Enter Details"
                                    press="EnterDetails"
                                />
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem5"
                                    text="Office 02"
                                />
                            </tnt:NavigationListItem>
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem6"
                                text="Mileage"
                                icon="sap-icon://mileage"
                            >
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem7"
                                    text="Driven"
                                />
                                <tnt:NavigationListItem
                                    text="Walked"
                                    id="walked"
                                />
                            </tnt:NavigationListItem>
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup1"
                            text="Recently used"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem8"
                                text="Managing My Area"
                                icon="sap-icon://kpi-managing-my-area"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem9"
                                text="Flight"
                                icon="sap-icon://flight"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem10"
                                text="Map"
                                icon="sap-icon://map-2"
                            />
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup2"
                            text="Restricted"
                            enabled="false"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem11"
                                text="Running"
                                icon="sap-icon://physical-activity"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem12"
                                text="Scissors"
                                icon="sap-icon://scissors"
                            />
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListItem
                            id="_IDGenNavigationListItem13"
                            text="Transport"
                            icon="sap-icon://passenger-train"
                        />
                    </tnt:NavigationList>
                    <tnt:fixedItem>
                        <tnt:NavigationList id="_IDGenNavigationList1">
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem14"
                                text="Bar Chart"
                                icon="sap-icon://bar-chart"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem15"
                                selectable="false"
                                href="https://sap.com"
                                target="_blank"
                                text="External Link"
                                icon="sap-icon://attachment"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem16"
                                selectable="false"
                                href="https://sap.com"
                                target="_top"
                                text="External Link _top"
                                icon="sap-icon://attachment"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem17"
                                text="Compare"
                                icon="sap-icon://compare"
                            />
                        </tnt:NavigationList>
                    </tnt:fixedItem>
                </tnt:SideNavigation>
            </VBox>

            <!-- main content -->
            <!-- panel 1  -->
            <VBox id="_IDGenVBox1">
                <Panel
                    id="Panel2"
                    headerText="Register Details"
                    visible="true"
                    class="sapUiResponsiveMargin"
                >
                    <!-- Events table -->
                    <Table
                        id="eventsTable"
                        items="{/peopleRegistrations}"
                    >
                        <columns>
                            <Column id="_IDGenColumn">
                                <Text
                                    id="_IDGenText"
                                    text="ID"
                                />
                            </Column>

                            <Column id="_IDGenColumn1">
                                <Text
                                    id="_IDGenText1"
                                    text="Event Name"
                                />
                            </Column>

                            <Column id="_IDGenColumn2">
                                <Text
                                    id="_IDGenText2"
                                    text="Location"
                                />
                            </Column>

                            <Column id="_IDGenColumn3">
                                <Text
                                    id="_IDGenText3"
                                    text="Date"
                                />
                            </Column>

                            <Column id="_IDGenColumn4">
                                <Text
                                    id="_IDGenText4"
                                    text="Available Seats"
                                />
                            </Column>

                            <Column id="_IDGenColumn6">
                                <Button
                                    id="_IDGenButton"
                                    type="Default"
                                    text=""
                                    press="onPress"
                                    ariaDescribedBy="acceptButtonDescription genericButtonDescription"
                                >
                                
                                </Button>
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem id="_IDGenColumnListItem1">
                                <cells>
                                    <Text
                                        id="_IDGenText5"
                                        text="{ID}"
                                    />
                                    <Text
                                        id="_IDGenText6"
                                        text="{eventName}"
                                    />
                                    <Text
                                        id="_IDGenText7"
                                        text="{location}"
                                    />
                                    <Text
                                        id="_IDGenText8"
                                        text="{date}"
                                    />
                                    <Text
                                        id="_IDGenText9"
                                        text="{availableSeats}"
                                    />

                                    <Button
                                        id="_IDGenButton3"
                                        text="Register"
                                        type="Accept"
                                        press="onRegisterPress"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <!-- panel 2  -->
                <Panel
                    id="Panel3"
                    headerText="Event Details"
                    visible="false"
                    class="sapUiResponsiveMargin"
                >
                    <Table
                        id="registrationtable"
                        items="{
        path: '/peopleRegistrations',
        parameters:{ $expand:'registed'}
    }"
                    >
                        <columns>
                            <Column id="_IDGenColumn5">
                                <Text
                                    id="_IDGenText11"
                                    text="ID"
                                />
                            </Column>

                            <Column id="_IDGenColumn7">
                                <Text
                                    id="_IDGenText12"
                                    text="Event Name"
                                />
                            </Column>

                            <Column id="_IDGenColumn8">
                                <Text
                                    id="_IDGenText13"
                                    text="Location"
                                />
                            </Column>

                            <Column id="_IDGenColumn9">
                                <Text
                                    id="_IDGenText14"
                                    text="Date"
                                />
                            </Column>

                      

                            <Column id="_IDGenColumn11">
                                <Text
                                    id="_IDGenText16"
                                    text="participantsName"
                                />
                            </Column>

                            <Column id="_IDGenColumn12">
                                <Text
                                    id="_IDGenText17"
                                    text="email"
                                />
                            </Column>

                            <Column id="_IDGenColumn13">
                                <Text
                                    id="_IDGenText18"
                                    text="phone"
                                />
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem id="_IDGenColumnListItem">
                                <cells>
                                    <Text
                                        id="_IDGenText19"
                                        text="{ID}"
                                    />
                                    <Text
                                        id="_IDGenText20"
                                        text="{eventName}"
                                    />
                                    <Text
                                        id="_IDGenText21"
                                        text="{location}"
                                    />
                                    <Text
                                        id="_IDGenText22"
                                        text="{date}"
                                    />
                                 
                                    <Text
                                        id="_IDGenText24"
                                        text="{registed/0/participantsName}"
                                    />
                                    <Text
                                        id="_IDGenText25"
                                        text="{registed/0/email}"
                                    />
                                    <Text
                                        id="_IDGenText26"
                                        text="{registed/0/phone}"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
                   <Panel
                    id="Panel4"
                    headerText="Enter the  Details"
                    visible="true"
                    class="sapUiResponsiveMargin"
                >

                <HBox
                    id="_IDGenHBox2"
                    visible="false"
                >
                    <VBox id="_IDGenVBox2">
                        <Label
                            id="_IDGenLabel2"
                            text="Participant Name"
                        />
                        <Input
                            id="participantsName"
                            placeholder="Enter participant name"
                        />
                    </VBox>

                    <VBox id="_IDGenVBox3">
                        <Label
                            id="_IDGenLabel3"
                            text="Email"
                        />
                        <Input
                            id="email"
                            placeholder="Enter your email"
                        />
                    </VBox>

                    <VBox id="_IDGenVBox4">
                        <Label
                            id="_IDGenLabel4"
                            text="Phone"
                        />
                        <Input
                            id="phone"
                            placeholder="Enter your phone number"
                        />
                    </VBox>
                    <VBox id="_IDGenVBox5">
                        <Button
                            id="submitBtn"
                            text="Submit"
                            type="Emphasized"
                            press="onSubmit"
                        />
                    </VBox>
                </HBox>
                </Panel>
            </VBox>
        </HBox>
    </Page>
</mvc:View>
